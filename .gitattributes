# Normalize line endings. Without this, core.autocrlf=true on Windows rewrites
# shell scripts to CRLF on checkout and bash fails with `$'\r': command not found`
# (or `/usr/bin/env bash\r: No such file`).

# Default: let git decide text vs binary, normalize to LF in the repo.
* text=auto

# Files that MUST stay LF regardless of platform (executed by bash/sh).
*.sh        text eol=lf
*.bash      text eol=lf
Dockerfile  text eol=lf
*.env       text eol=lf
.env.*      text eol=lf

# Windows-only scripts keep CRLF.
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf
