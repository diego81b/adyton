# @adyton/shared is consumed as raw TS source (exports -> ./src/index.ts), so the
# bundler of each consumer (web Vite, extension, api) must resolve shared's runtime
# deps directly. pnpm's strict symlinking keeps those deps under
# packages/shared/node_modules only, where consumer bundlers don't look, which breaks
# Vite import-analysis (e.g. /register failing to resolve @zxcvbn-ts/core, hash-wasm).
# Hoist exactly those client-bundled deps to the workspace-root node_modules so every
# consumer resolves them flat. Scoped to these packages only to preserve pnpm strictness
# everywhere else. Long-term fix (Phase 8): build @adyton/shared to dist and drop this.
# NOTE: setting public-hoist-pattern[] overrides pnpm's built-in defaults
# (*eslint*, *prettier*), so they must be repeated here or root eslint.config.js
# fails to resolve @eslint/js.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=hash-wasm
public-hoist-pattern[]=@zxcvbn-ts/*
