# Adyton — .env.example
# Placeholders only. Copy to `.env` and fill in real values. Never commit `.env`.

# ───── PostgreSQL (dev defaults; rotate before any non-localhost use) ─────
POSTGRES_PASSWORD=devpassword

# ───── Frontend ─────
# In dev, nginx fronts both services on port 80. The browser hits /api/* and
# nginx rewrites to the api container. See nginx.dev.conf.
NUXT_PUBLIC_API_BASE_URL=http://localhost/api

# ───── Backend ─────
# Dev mounts the keypair as Docker secrets — these paths are read by NestJS.
# In production, JWT_PRIVATE_KEY / JWT_PUBLIC_KEY are passed as multiline env vars
# (see analysis/infrastructure.md §9.5) and these *_PATH vars are not set.
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key

# CORS allowlist for the API.
ALLOWED_ORIGINS=http://localhost

# Feature flag for PoW challenge endpoint (lands in Phase 2). Default off in V1.
ENABLE_POW=false

# ───── Production-only (commented; documented for completeness) ─────
# REDIS_PASSWORD=CHANGE_ME_32_BYTES_HEX
# DOMAIN=vault.yourdomain.com
# API_IMAGE=ghcr.io/yourorg/adyton-api:latest
# WEB_IMAGE=ghcr.io/yourorg/adyton-web:latest
