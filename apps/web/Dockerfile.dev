# syntax=docker/dockerfile:1.7
FROM node:22-alpine

ENV CI=true
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

RUN apk add --no-cache libc6-compat \
    && corepack enable \
    && corepack prepare pnpm@9.15.4 --activate

WORKDIR /app

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./
COPY apps/web/package.json ./apps/web/
COPY packages/shared/package.json ./packages/shared/

# .npmrc carries the public-hoist-pattern that lifts shared's client-bundled deps
# (hash-wasm, zxcvbn) into root node_modules so web's Vite can resolve them.
RUN pnpm install --frozen-lockfile

COPY apps/web ./apps/web
COPY packages/shared ./packages/shared
COPY tsconfig.base.json ./

EXPOSE 3000

# HOST=0.0.0.0 env var (set above) makes Nuxi/Listhen bind to all interfaces;
# do NOT also pass --host on the command line: Nuxi parses it ambiguously
# when forwarded via `pnpm --filter ... -- ...` and creates a spurious
# `--host/` directory with the trailing value treated as a positional rootDir.
CMD ["pnpm", "--filter", "@adyton/web", "dev"]
