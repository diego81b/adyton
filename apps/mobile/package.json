{
  "name": "@adyton/mobile",
  "version": "0.0.0",
  "private": true,
  "description": "Adyton Mobile — Capacitor shell wrapping the apps/web static build",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "assets": "node scripts/generate-assets.mjs && capacitor-assets generate --android --ios",
    "build:web": "pnpm --filter @adyton/web generate",
    "sync": "cap sync",
    "sync:android": "cap sync android",
    "sync:ios": "cap sync ios",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "run:android": "cap run android",
    "run:ios": "cap run ios"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@aparajita/capacitor-secure-storage": "^8.0.0",
    "@capacitor-community/safe-area": "^8.0.1",
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/splash-screen": "^8.0.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.0",
    "sharp": "^0.35.1",
    "typescript": "^5.7.2"
  }
}
